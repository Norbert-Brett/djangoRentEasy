{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "DOCKER"
    },
    "deploy": {
        "numReplicas": 1,
        "startCommand": "python manage.py migrate && gunicorn djangorenteasy.wsgi --log-file -",
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
    }
}